# 냉파튜브 environment variables — all optional.
# The app runs fully offline with curated fallback data when these are unset.

# Claude API — powers /api/recommend (dish recommendations).
# Without it, recommendations fall back to lib/fallback.ts.
ANTHROPIC_API_KEY=

# YouTube Data API v3 — powers /api/videos (recipe videos).
# Without it, videos fall back to curated placeholders.
YOUTUBE_API_KEY=

# Upstash Redis (REST) — caches YouTube results by normalized dish name.
# Without it, caching is a no-op.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
